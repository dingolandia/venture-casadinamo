{
  "name": "casadinamo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev": "concurrently npm:dev:*",
    "build": "tsc && node -e \"const fs=require('fs'); fs.cpSync('src/ui-assets', 'dist/src/ui-assets', {recursive:true}); fs.cpSync('src/ui-extensions', 'dist/src/ui-extensions', {recursive:true});\"",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "postinstall": "node ./patch-vendure-ui.js"
  },
  "dependencies": {
    "@vendure/admin-ui-plugin": "3.5.5",
    "@vendure/asset-server-plugin": "3.5.5",
    "@vendure/core": "3.5.5",
    "@vendure/email-plugin": "3.5.5",
    "@vendure/graphiql-plugin": "3.5.5",
    "archiver": "^7.0.1",
    "better-sqlite3": "12.2.0",
    "dotenv": "17.2.2",
    "express": "5.1.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@vendure/cli": "3.5.5",
    "@vendure/ui-devkit": "3.5.5",
    "concurrently": "9.2.1",
    "typescript": "5.8.2"
  }
}
